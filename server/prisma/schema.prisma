// Datasource and generator
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  STUDENT
  SCHOOL_ADMIN
  HEADMASTER
}

enum MediaType {
  IMAGE
  VIDEO
}

enum DocumentType {
  STUDENT_ID
  TRANSCRIPT
  OTHER
}

enum GroupMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum Visibility {
  PUBLIC
  GROUP
}

// Models
model User {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Firebase UID for auth linkage
  uid            String    @unique

  email          String?   @unique
  handle         String    @unique
  displayName    String
  bio            String?   @db.Text
  avatarUrl      String?
  bannerUrl      String?

  role           UserRole  @default(STUDENT)
  isPremium      Boolean   @default(false)

  // Relations
  tweets         Tweet[]
  comments       Comment[]
  likes          Like[]
  following      Follow[]  @relation("following")
  followers      Follow[]  @relation("followers")

  school         School?   @relation(fields: [schoolId], references: [id])
  schoolId       String?

  documents      Document[]
  groupsOwned    Group[]   @relation("groupsOwned")
  groupMembers   GroupMember[]
  invitesSent    GroupInvite[] @relation("invitesSent")
  invitesReceived GroupInvite[] @relation("invitesReceived")

  @@index([handle])
  @@index([email])
}

model Tweet {
  id             String     @id @default(cuid())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  author         User       @relation(fields: [authorId], references: [id])
  authorId       String

  content        String     @db.Text
  visibility     Visibility @default(PUBLIC)

  // If set, this is a group post
  group          Group?     @relation(fields: [groupId], references: [id])
  groupId        String?

  // denormalized counters for performance
  likeCount      Int        @default(0)
  commentCount   Int        @default(0)

  media          Media[]
  likes          Like[]
  comments       Comment[]

  @@index([authorId, createdAt])
  @@index([createdAt])
}

model Media {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())

  tweet     Tweet     @relation(fields: [tweetId], references: [id])
  tweetId   String

  type      MediaType
  url       String
  width     Int?
  height    Int?
  duration  Int?      // seconds for video
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    String

  tweet     Tweet    @relation(fields: [tweetId], references: [id])
  tweetId   String

  @@unique([userId, tweetId])
  @@index([tweetId])
}

model Comment {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author         User      @relation(fields: [authorId], references: [id])
  authorId       String

  tweet          Tweet     @relation(fields: [tweetId], references: [id])
  tweetId        String

  content        String    @db.Text

  // Optional threading
  parent         Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  parentId       String?
  children       Comment[] @relation("CommentThread")

  @@index([tweetId])
}

model Follow {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  follower    User     @relation("followers", fields: [followerId], references: [id])
  followerId  String

  following   User     @relation("following", fields: [followingId], references: [id])
  followingId String

  @@unique([followerId, followingId])
  @@index([followingId])
}

model School {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  name          String
  domain        String?   @unique
  address       String?
  verified      Boolean   @default(false)

  headmaster    User?     @relation(fields: [headmasterUserId], references: [id])
  headmasterUserId String?

  users         User[]
  groups        Group[]

  @@index([name])
}

model Document {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id])
  userId      String

  type        DocumentType
  url         String
  verified    Boolean      @default(false)
}

model Group {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  name        String
  isPrivate   Boolean       @default(true)

  owner       User          @relation("groupsOwned", fields: [ownerId], references: [id])
  ownerId     String

  school      School?       @relation(fields: [schoolId], references: [id])
  schoolId    String?

  members     GroupMember[]
  invites     GroupInvite[]
  tweets      Tweet[]
}

model GroupMember {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())

  group       Group           @relation(fields: [groupId], references: [id])
  groupId     String

  user        User            @relation(fields: [userId], references: [id])
  userId      String

  role        GroupMemberRole @default(MEMBER)

  @@unique([groupId, userId])
}

model GroupInvite {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  group       Group        @relation(fields: [groupId], references: [id])
  groupId     String

  inviter     User         @relation("invitesSent", fields: [inviterId], references: [id])
  inviterId   String

  invitee     User         @relation("invitesReceived", fields: [inviteeId], references: [id])
  inviteeId   String

  status      InviteStatus @default(PENDING)

  @@index([groupId])
  @@unique([groupId, inviteeId])
}